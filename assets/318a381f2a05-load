  /* ---------- 1. Add an Esc-key listener ---------- */
const escHandler = evt => {
  if (evt.key === 'Escape' || evt.key === 'Esc') {
/* Try to close via tp.offer first (Offer templates) …  */
    if (tp.offer && typeof tp.offer.close === 'function') {
/* Check if the component with the id #fullscreen-modal is active, if it is, remove its css class */
      let a = document.querySelector("#fullscreen-modal");
		if(a){
         	a.classList.remove('tp-modal');
         }
       a.remove();
      tp.offer.close();
/* …otherwise fall back to tp.template.close() */
    } else if (tp.template && typeof tp.template.close === 'function') {
      tp.template.close();
    }
  }
};
document.addEventListener('keydown', escHandler, false);

/* ---------- 2. Clean up after the modal is closed ---------- */
tp.push(['addHandler', 'checkoutClose', function () {
  document.removeEventListener('keydown', escHandler, false);
}]);
   
