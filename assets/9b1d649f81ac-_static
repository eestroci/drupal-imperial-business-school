/**
 * Checks for user consent via TCF or USP APIs and loads the Alchemer script if
 * consent is present.
 *
 * Uses vendor ID 28 for Alchemer (TCF) and global consent for USP API.
 *
 * @returns {void}
 */
function alchemerConsentHandler() {
	const nrvVendorId = 28;

	if (window.__tcfapi) {
		window.__tcfapi('getValidTCData', 2, () => {
			window.__tcfapi('getNonRegisteredVendorsConsents', 2, (nrvList) => {
				if (nrvList && nrvList?.[nrvVendorId]?.consent) {
					addAlchemerScript();
				}
			});
		});
	} else if (window.__uspapi) {
		// US Yes/No check.
		window.__uspapi('getUSPData', 1, () => {
			window.__uspapi.a.push([
				'hasConsentedToAll',
				null,
				(hasConsent) => {
					if (hasConsent) addAlchemerScript();
				}
			]);
		});
