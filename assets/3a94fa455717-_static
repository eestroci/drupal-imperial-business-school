(function () {
    
    const COOKIE = "LandingPage";
    const MAX_AGE_DAYS = 30;

    const href = window.location.href;
    const path = window.location.pathname || "";

    // Load funnel paths from WP
    const funnelPaths = (window.coeditorLandingConfig?.funnelPaths || [])
        .map(p => p.trim())
        .filter(Boolean);

    // Check if page matches any admin-defined funnel path
    const isFunnel = funnelPaths.some(fp => path.startsWith(fp));
    if (isFunnel) return;

    const maxAge = MAX_AGE_DAYS * 24 * 60 * 60;
    const secure = window.location.protocol === "https:" ? "; Secure" : "";

    document.cookie =
      `${COOKIE}=${encodeURIComponent(href)}; Max-Age=${maxAge}; Path=/; SameSite=Lax${secure}`;
})();

